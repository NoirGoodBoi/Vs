local UI = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/NoirGoodBoi/UI/main/noiruiv1"
))()

local Window = UI:CreateWindow({
    Name = "Noir Cape ⚡",
    SoundId = "rbxassetid://9118823101",
    IconEffect = true
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer

local Config = {
    Enabled = false,
    Rainbow = false,
    Size = 1,
    Height = 0.85,
    Color = Color3.fromRGB(0,0,0),
    Text = "NOIR"
}

local Cape
local Loop
local Label

local function CreateCape()
    local char = Player.Character or Player.CharacterAdded:Wait()
    local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
    local root = char:FindFirstChild("HumanoidRootPart")

    if not torso or not root then return end
    if not Config.Enabled then return end

    if Cape then Cape:Destroy() Cape = nil end
    if Loop then Loop:Disconnect() Loop = nil end

    Cape = Instance.new("Part")
    Cape.Name = "NoirCape"
    Cape.Parent = char
    Cape.Size = Vector3.new(1.6 * Config.Size, 2.8 * Config.Size, 0.01)
    Cape.CanCollide = false
    Cape.Massless = true
    Cape.Material = Enum.Material.SmoothPlastic
    Cape.Color = Config.Color

    local motor = Instance.new("Motor6D")
    motor.Part0 = torso
    motor.Part1 = Cape
    motor.Parent = Cape

    motor.C0 = CFrame.new(0, Config.Height, 0.6)
    motor.C1 = CFrame.new(0, 1.4 * Config.Size, 0)

    local gui = Instance.new("SurfaceGui")
    gui.Parent = Cape
    gui.Face = Enum.NormalId.Back
    gui.CanvasSize = Vector2.new(400, 500)
    gui.AlwaysOnTop = true

    Label = Instance.new("TextLabel")
    Label.Parent = gui
    Label.Size = UDim2.new(1,0,1,0)
    Label.BackgroundTransparency = 1
    Label.Text = Config.Text
    Label.TextColor3 = Color3.new(1,1,1)
    Label.Font = Enum.Font.GothamBold
    Label.TextScaled = true
    Label.TextWrapped = true
    Label.TextXAlignment = Enum.TextXAlignment.Center
    Label.TextYAlignment = Enum.TextYAlignment.Center

    Loop = RunService.RenderStepped:Connect(function()
        if not Cape or not Cape.Parent then return end

        local t = tick()
        local speed = root.Velocity.Magnitude

        if Config.Rainbow then
            Cape.Color = Color3.fromHSV(t % 5 / 5, 1, 1)
        else
            Cape.Color = Config.Color
        end

        if speed > 2 then
            motor.C0 = motor.C0:Lerp(
                CFrame.new(0, Config.Height, 0.6) * CFrame.Angles(math.rad(-60 + math.sin(t*16)*3),0,0),
                0.15
            )
        else
            motor.C0 = motor.C0:Lerp(
                CFrame.new(0, Config.Height, 0.6) * CFrame.Angles(math.rad(-10 + math.sin(t*2)*5),0,0),
                0.05
            )
        end
    end)
end

local function ParseRGB(text)
    local r,g,b = string.match(text, "(%d+)%s*,%s*(%d+)%s*,%s*(%d+)")
    if r and g and b then
        return Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
    end
    return nil
end

Window:CreateToggle({
    Name = "Enable Cape",
    Callback = function(v)
        Config.Enabled = v

        if v then
            CreateCape()
        else
            if Cape then Cape:Destroy() Cape = nil end
            if Loop then Loop:Disconnect() Loop = nil end
        end
    end
})

Window:CreateToggle({
    Name = "Rainbow Cape",
    Callback = function(v)
        Config.Rainbow = v
    end
})

Window:CreateTextBox({
    Name = "Height (0 - 1)",
    Callback = function(text)
        local n = tonumber(text)
        if n then
            Config.Height = math.clamp(n, 0, 1)
        end
    end
})

Window:CreateTextBox({
    Name = "Size",
    Callback = function(text)
        local n = tonumber(text)
        if n then
            Config.Size = math.clamp(n, 0.5, 3)
        end
    end
})

Window:CreateTextBox({
    Name = "Color (R,G,B)",
    Callback = function(text)
        local c = ParseRGB(text)
        if c then
            Config.Color = c
        end
    end
})

Window:CreateButton({
    Name = "Apply Color",
    Callback = function()
        if Cape then
            Cape.Color = Config.Color
        end
    end
})

Window:CreateTextBox({
    Name = "Cape Text",
    Callback = function(text)
        Config.Text = text
        if Label then
            Label.Text = text
        end
    end
})

Window:CreateButton({
    Name = "Apply Text",
    Callback = function()
        if Label then
            Label.Text = Config.Text
        end
    end
})
